# ============================================================
#  FORESTWATCH — Variables d'environnement
#  Copier en .env et remplir les valeurs manquantes
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=FORESTWATCH
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logs ─────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Base de données ──────────────────────────────────────────
# Développement local — MySQL (LAMPP)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=forestwatch
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=/opt/lampp/var/mysql/mysql.sock

# Production Render — PostgreSQL (valeurs injectées automatiquement)
# DB_CONNECTION=pgsql
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=forestwatch
# DB_USERNAME=
# DB_PASSWORD=

# ── Sessions & Cache ─────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=480

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contact@forestwatch.gn"
MAIL_FROM_NAME="${APP_NAME}"
